# Travel Guide API Environment Variables

# JWT Secret (change this in production!)
JWT_SECRET=travel-guide-secret-key-change-in-production

# QQ OAuth Configuration
# 请在 QQ 互联开放平台申请 https://connect.qq.com/
QQ_APP_ID=你的QQ_APP_ID
QQ_APP_KEY=你的QQ_APP_KEY
QQ_CALLBACK_URL=http://study.roamhong.site/api/auth/qq/callback

# Server Port
PORT=3001
